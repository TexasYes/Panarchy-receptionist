# panarchy-receptionist — local environment file
#
# Copy this file to .env and fill in real values. .env is gitignored.
# Wrapper scripts in scripts/run-*.sh source .env automatically when present,
# so once you fill this in you can run any wrapper without pasting secrets.
#
# For RAILWAY (production), these same vars go in the Railway dashboard
# → Variables tab. The repo file matters only for local script execution.
#
# Cloned from dialog-receptionist 2026-05-21. The Vapi/LiveKit/SMS sections
# below are inherited from the source repo — set them only if you actually
# revive those flows for Panarchy.

# ── Branding (used by index.js email templates) ───────────────────────────────
COMPANY_NAME=Panarchy
# Header bg + accent bar in email templates. Defaults match the 2022 Panarchy
# brand guidelines (docs/Panarchy_Brand_Guidelines.md): Black + Red.
BRAND_PRIMARY=#000000
BRAND_ACCENT=#EF4124

# Public URL of THIS Railway service. Used for /logo URL inside email templates
# and for Twilio TwiML callbacks. Set after first Railway deploy.
SELF_BASE_URL=https://panarchy-receptionist-production.up.railway.app

# Panarchy production phone number (Twilio BYOT → Bland).
PRODUCTION_NUMBER=+12513335665

# ── Bland.ai (Panarchy's receptionist platform) ───────────────────────────────
# Reuse Dialog's Bland account key or create a fresh one for Panarchy — both work.
BLAND_API_KEY=
BLAND_ORG_ID=

# ── Google (employee directory in Google Sheets) ──────────────────────────────
# Create a new sheet for Panarchy with columns: name, phone, gender, email, conditions
# and paste the sheet ID here. Empty = falls back to FALLBACK_EMPLOYEES in index.js.
GOOGLE_API_KEY=
GOOGLE_SHEET_ID=1iPluCrn4fVbjtuQKJdLz0lj89WfHW-b4uv2yBfablH8

# ── Microsoft Graph (sends branded HTML emails from receptionist@panarchy.io) ──
# Requires an Azure app registration in the panarchy.io tenant with
# Application permission "Mail.Send" granted (and admin-consented).
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_SENDER_EMAIL=receptionist@panarchy.io
# Optional fallback if Graph blocks sending — Microsoft 365 app password.
SMTP_PASS=

# ── Daily summary recipient (8pm Central cron) ────────────────────────────────
DAILY_SUMMARY_EMAIL=bobgutermuth@panarchy.io
# Default timezone is America/Chicago. Override if needed.
# DAILY_SUMMARY_TZ=America/Chicago

# ── Admin (for /employees, /daily-summary endpoints) ──────────────────────────
ADMIN_API_KEY=

# ── Webhook auth (shared secret for Bland tools to hit Railway endpoints) ─────
# Renaming preserved from Dialog: env var is WEBHOOK_SHARED_SECRET for code-path
# compatibility; in practice it gates ALL receptionist-platform webhook calls.
WEBHOOK_SHARED_SECRET=

# ── Vapi (LEGACY — only set if you revive Vapi for Panarchy) ──────────────────
VAPI_PRIVATE_KEY=

# ── Twilio (only needed if you re-enable the SMS receptionist or warm transfer) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=+12513335665

# ── HubSpot (LEGACY — Panarchy has no HubSpot integration at launch) ──────────
HUBSPOT_API_KEY=

# ── LiveKit (LEGACY — only set if you revive LiveKit for Panarchy) ────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
